#!/usr/bin/env python3
"""bb-cover — fzf preview helper: render a game's box cover in the preview pane.

Given an fzf line (from c64menu or c64tosec), find the game's cover from the
libretro-thumbnails Commodore 64 set, cache it, and draw it with `wezterm imgcat`
sized to the preview pane. Falls back to a text label when no cover exists.

Covers: https://github.com/libretro-thumbnails/Commodore_-_64 (Named_Boxarts)
"""
import os, sys, re, json, subprocess, urllib.parse, urllib.request, importlib.machinery

HERE = os.path.dirname(os.path.abspath(__file__))
bi = importlib.machinery.SourceFileLoader("build_index", os.path.join(HERE, "build_index.py")).load_module()

CIDX = os.path.join(HERE, "covers_index.tsv")
CDIR = os.path.join(HERE, "covers")
TREE = "https://api.github.com/repos/libretro-thumbnails/Commodore_-_64/git/trees/master?recursive=1"
RAW  = "https://raw.githubusercontent.com/libretro-thumbnails/Commodore_-_64/master/Named_Boxarts/"
UA   = "breadbin-covers/1.0"

def fetch(url, headers=None):
    req = urllib.request.Request(url, headers=headers or {"User-Agent": UA})
    return urllib.request.urlopen(req, timeout=60).read()

def region_rank(name):
    n = name.lower()
    return 0 if "(world" in n else 1 if "(europe" in n else 2 if "(usa" in n else 3

def build_cover_index():
    tree = json.loads(fetch(TREE))["tree"]
    best = {}
    for p in tree:
        path = p.get("path", "")
        if not path.startswith("Named_Boxarts/") or not path.endswith(".png"):
            continue
        fn = path[len("Named_Boxarts/"):]
        canon = bi.norm(re.split(r"\s*\(", fn[:-4], maxsplit=1)[0])   # drop "(Region)" + .png
        rank = region_rank(fn)
        if canon and (canon not in best or rank < best[canon][0]):
            best[canon] = (rank, fn)
    with open(CIDX, "w", encoding="utf-8") as f:
        for c, (_, fn) in best.items():
            f.write(f"{c}\t{fn}\n")

def load_index():
    if not os.path.exists(CIDX):
        build_cover_index()
    return dict(l.rstrip("\n").split("\t", 1) for l in open(CIDX, encoding="utf-8") if "\t" in l)

def ensure_cover(canon, idx):
    """Return the cached cover path for a game (downloading once), or None."""
    fn = idx.get(canon)
    if not fn:
        return None
    os.makedirs(CDIR, exist_ok=True)
    cache = os.path.join(CDIR, canon + ".png")
    if not os.path.exists(cache) or os.path.getsize(cache) == 0:
        try: open(cache, "wb").write(fetch(RAW + urllib.parse.quote(fn)))
        except Exception: return None
    return cache

def prefetch():
    """Download covers for every game in the menu index, ahead of time."""
    INDEX = os.path.join(HERE, "c64_index.tsv")
    idx = load_index()
    rows = [l.rstrip("\n").split("\t") for l in open(INDEX, encoding="utf-8")]
    have = miss = 0
    for f in rows:
        if len(f) < 5: continue
        canon = bi.norm(re.split(r":| - ", f[4], maxsplit=1)[0])
        if ensure_cover(canon, idx): have += 1
        else: miss += 1
    print(f"covers cached: {have}  (no cover available: {miss})  -> {CDIR}", file=sys.stderr)

def main(argv):
    if len(argv) > 1 and argv[1] == "--prefetch":
        prefetch(); return

    line = argv[1] if len(argv) > 1 else ""
    fields = line.split("\t")
    key = fields[-1] if fields else line                       # query (menu) or canon (tosec)
    canon = bi.norm(re.split(r":| - ", key, maxsplit=1)[0])
    label = fields[3] if len(fields) >= 4 else (fields[0] if fields else key)
    label = re.sub(r"^[●⬇·\s]+\d*\.?\s*", "", label)           # strip markers/rank for display

    try: idx = load_index()
    except Exception: print(f"  {label}\n\n  (cover index unavailable)"); return
    cache = ensure_cover(canon, idx)
    if not cache:
        print(f"  {label}\n\n  (no cover found)"); return

    cols = os.environ.get("FZF_PREVIEW_COLUMNS", "40")
    lines = os.environ.get("FZF_PREVIEW_LINES", "25")
    subprocess.run(["wezterm", "imgcat", "--width", cols, "--height", lines, cache],
                   check=False)

if __name__ == "__main__":
    main(sys.argv)
