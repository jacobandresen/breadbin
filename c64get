#!/usr/bin/env python3
"""c64get - find and download C64 games from the Ultimate Tape Archive (UTA).

UTA (https://uta.pokefinder.org/) is a tape-preservation project: one folder per
game, each holding .tap image(s) plus scans. This downloads the .tap file(s) into
your collection so `c64menu --refresh` can pick them up.

Usage:
  c64get <title> [<title> ...]   search UTA for each title and download the .tap(s)
  c64get --missing               download the missing Lemon64 top-100 games found in UTA
  c64get -n / --list <title>     dry run: show what would be downloaded, don't fetch
  c64get --dest DIR              download directory (default: <collection>/_UTA_downloads)
  c64get --refresh-index         re-download the UTA directory listing first

Matching:
  --missing uses strict equality (no human in the loop -> avoid wrong games).
  Title queries use substring match; if several folders match and you're on a
  terminal, you pick from an fzf list (multi-select with TAB).
"""
import os, re, sys, time, html, urllib.parse, urllib.request, subprocess

HERE       = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, HERE)
from build_index import norm, title_key            # reuse the exact matching logic

BASE       = "https://uta.pokefinder.org/Ultimate_Tape_Archive/"
IDX_CACHE  = os.path.join(HERE, "uta_index.html")
POP        = os.path.join(HERE, "c64_popularity.tsv")
INDEX      = os.path.join(HERE, "c64_index.tsv")
DEST_DFLT  = "/opt/media/Games/Commodore/C64 Roms/_UTA_downloads"
UA         = "c64get/1.0 (personal C64 collection tool; polite, low-volume)"
TAP_MAGIC  = b"C64-TAPE-RAW"

def log(*a): print(*a, file=sys.stderr)

def fetch(url, binary=False):
    req = urllib.request.Request(url, headers={"User-Agent": UA})
    with urllib.request.urlopen(req, timeout=60) as r:
        data = r.read()
    return data if binary else data.decode("utf-8", "replace")

def load_index(refresh=False):
    if refresh or not os.path.exists(IDX_CACHE):
        log("Fetching UTA directory listing ...")
        open(IDX_CACHE, "w", encoding="utf-8").write(fetch(BASE))
    txt = open(IDX_CACHE, encoding="utf-8", errors="replace").read()
    folders = sorted(set(re.findall(r'href="([^"/]+%5[bB][0-9]+%5[dD])/?"', txt)))
    fmap = []          # list of (norm_title, display, href)
    for f in folders:
        name  = html.unescape(urllib.parse.unquote(f))
        title = re.split(r"\s*\((?:\d{4}|19xx)", name.replace("_", " "), maxsplit=1)[0]
        fmap.append((norm(title), name, f))
    return fmap

def find_exact(fmap, key):
    return [(d, h) for nk, d, h in fmap if nk == key]

def find_substr(fmap, q):
    qn = norm(q)
    return [(d, h) for nk, d, h in fmap if qn and qn in nk]

def pick_with_fzf(matches):
    if not sys.stdin.isatty() or not _have("fzf"):
        return None  # caller falls back to listing
    lines = "\n".join(d for d, _ in matches)
    r = subprocess.run(["fzf", "--multi", "--reverse", "--prompt", "UTA pick (TAB=multi) > "],
                       input=lines, capture_output=True, text=True)
    chosen = set(r.stdout.split("\n")) - {""}
    return [(d, h) for d, h in matches if d in chosen]

def _have(cmd):
    return subprocess.run(["which", cmd], capture_output=True).returncode == 0

def download_folder(href, dest, dry):
    """Download every .tap in a UTA game folder. Returns list of saved paths."""
    folder_url = urllib.parse.urljoin(BASE, href + "/")
    page = fetch(folder_url)
    taps = sorted(set(re.findall(r'href="([^"/?]+\.tap)"', page, re.I)))
    if not taps:
        log("    (no .tap in folder - skipped)"); return []
    saved = []
    for t in taps:
        url  = urllib.parse.urljoin(folder_url, t)
        name = html.unescape(urllib.parse.unquote(t))
        out  = os.path.join(dest, name)
        if dry:
            log(f"    would download: {name}"); continue
        if os.path.exists(out) and os.path.getsize(out) > 0:
            log(f"    exists, skip: {name}"); saved.append(out); continue
        data = fetch(url, binary=True)
        if not data.startswith(TAP_MAGIC):
            log(f"    !! not a TAP (got {len(data)}B, bad signature) - skipped: {name}")
            continue
        os.makedirs(dest, exist_ok=True)
        open(out, "wb").write(data)
        log(f"    saved: {name} ({len(data)//1024} KB)")
        saved.append(out)
        time.sleep(1)        # be a polite client
    return saved

def missing_titles():
    # index columns: display, status, target, title, query
    out = []
    for l in open(INDEX, encoding="utf-8"):
        f = l.rstrip("\n").split("\t")
        if len(f) >= 5 and f[1] == "missing":
            out.append(f[4])
    return out

def main(argv):
    dry = refresh = use_missing = False
    dest = DEST_DFLT
    queries = []
    i = 0
    while i < len(argv):
        a = argv[i]
        if a in ("-n", "--list"):      dry = True
        elif a == "--missing":         use_missing = True
        elif a == "--refresh-index":   refresh = True
        elif a == "--dest":            i += 1; dest = argv[i]
        elif a in ("-h", "--help"):    print(__doc__); return 0
        elif a.startswith("-"):        log(f"unknown option: {a}"); return 2
        else:                          queries.append(a)
        i += 1

    if not use_missing and not queries:
        log("nothing to do: give a title, or --missing (see --help)"); return 2

    fmap = load_index(refresh)
    log(f"UTA index: {len(fmap)} games\n")

    # build the target folder set
    targets = {}    # display -> href
    if use_missing:
        for t in missing_titles():
            for d, h in find_exact(fmap, title_key(t)):
                targets[d] = h
        log(f"missing top-100 found in UTA: {len(targets)}")
    for q in queries:
        m = find_exact(fmap, norm(q)) or find_substr(fmap, q)
        if not m:
            log(f'"{q}": no match in UTA'); continue
        if len(m) == 1:
            targets[m[0][0]] = m[0][1]
        else:
            chosen = pick_with_fzf(m)
            if chosen is None:           # non-interactive: just list, don't guess
                log(f'"{q}": {len(m)} matches - narrow it or run on a terminal:')
                for d, _ in m[:20]: log("    " + d)
            else:
                for d, h in chosen: targets[d] = h

    if not targets:
        log("\nnothing matched to download."); return 1

    log(f"\n{'(dry run) ' if dry else ''}processing {len(targets)} game(s) -> {dest}\n")
    total = 0
    for d in sorted(targets):
        log(f"* {d}")
        total += len(download_folder(targets[d], dest, dry))
    log(f"\n{'would download' if dry else 'downloaded'} {total} .tap file(s).")
    if total and not dry:
        log("run  c64menu --refresh  to add them to the picker.")
    return 0

if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
