#!/usr/bin/env bash
#
# c64menu — pick a ranked C64 game and launch (or fetch) it.
#
# Lists ranked C64 games you own or can download, marking availability. Games that
# can't be found in your collection or any download source are skipped.
#     ●  in your collection   →  Enter boots it via c64run (real LOAD"*",8,1 : RUN)
#     ⬇  downloadable         →  Enter fetches it via c64disk, then boots it.
#
# Usage:
#   c64menu            # open the fuzzy picker
#   c64menu -w         # pass --warp (fast-load) to c64run
#   c64menu -f         # pass --fullscreen to c64run
#   c64menu -r         # pass --real (true drive emulation) to c64run
#   c64menu --refresh  # re-pull popularity scores, re-scan availability, rebuild
#
set -euo pipefail

HERE="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
POP="$HERE/c64_popularity.tsv"
INDEX="$HERE/c64_index.tsv"
BUILD="$HERE/build_index.py"
DISK="$HERE/c64disk"
VOTES_URL="https://www.lemon64.com/games/votes_list.php"

C64RUN_OPTS=()
die() { printf 'c64menu: %s\n' "$*" >&2; exit 1; }

refresh() {
  echo "Fetching popularity scores..." >&2
  local html; html="$(mktemp)"
  curl -sL --max-time 30 "$VOTES_URL" -o "$html" || die "could not fetch popularity scores"
  python3 - "$html" "$POP" <<'PY' || die "could not parse popularity page"
import re, html as H, sys
src, out = sys.argv[1], sys.argv[2]
t = open(src, encoding="utf-8", errors="replace").read()
rows = []
for b in t.split("votes-list-game-container")[1:]:
    sc = re.search(r'votes-list-score">([\d.]+)<', b)
    vo = re.search(r'>([\d,]+)&nbsp;votes', b)
    ti = re.search(r'<h3[^>]*><a[^>]*class="bold-blue"[^>]*>([^<]+)</a>', b)
    if sc and ti:
        rows.append((sc.group(1),
                     (vo.group(1).replace(",", "") if vo else "0"),
                     H.unescape(ti.group(1)).strip()))
with open(out, "w", encoding="utf-8") as f:
    for i, (s, v, ti) in enumerate(rows, 1):
        f.write(f"{i}\t{s}\t{v}\t{ti}\n")
print(f"  {len(rows)} ranked games pulled", file=sys.stderr)
PY
  python3 "$BUILD" >/dev/null 2>&1                 # local set, so the scan knows what's owned
  "$DISK" --scan-missing --source all || true      # which not-owned games are downloadable
  python3 "$BUILD"                                  # rebuild: local + downloadable, skip the rest
}

# --- flags -------------------------------------------------------------------
while [[ ${1:-} == -* ]]; do
  case "$1" in
    -w|--warp)       C64RUN_OPTS+=( -w ) ;;
    -f|--fullscreen) C64RUN_OPTS+=( -f ) ;;
    -r|--real)       C64RUN_OPTS+=( -r ) ;;
    --refresh)       refresh; [[ ${2:-} ]] || exit 0 ;;
    -h|--help)       sed -n '3,16p' "$0"; exit 0 ;;
    *)               die "unknown option: $1 (try --help)" ;;
  esac
  shift
done

command -v fzf >/dev/null || die "fzf not found"
[[ -f "$INDEX" ]] || refresh
[[ -s "$INDEX" ]] || die "index is empty (try: c64menu --refresh)"

have=$(grep -cP '\tlocal\t'     "$INDEX" || true)
getn=$(grep -cP '\tavailable\t' "$INDEX" || true)
choice="$(
  fzf --with-nth=1 --delimiter='\t' \
      --height=90% --reverse --no-sort --cycle \
      --prompt='C64 ▶ ' \
      --header="C64 games · ●$have here / ⬇$getn downloadable · Enter: play, or fetch+play" \
      --preview "'$HERE/bb-cover' {}" --preview-window='right,40%,border-left' \
      < "$INDEX"
)" || exit 0   # Esc / Ctrl-C = cancel

[[ -n "$choice" ]] || exit 0
status="$(printf '%s' "$choice" | cut -f2)"
target="$(printf '%s' "$choice" | cut -f3)"
title="$( printf '%s' "$choice" | cut -f4)"
query="$( printf '%s' "$choice" | cut -f5)"

# 1) already local -> just launch
if [[ "$status" == local ]]; then
  exec c64run "${C64RUN_OPTS[@]}" "$target"
fi

# 2) downloadable -> fetch via c64disk from the source the scan found it in
command -v c64disk >/dev/null || die "c64disk not found"
printf '"%s" is not in your collection (downloadable from %s).\n' "$title" "$target" >&2
read -r -p "Download and play? [Y/n] " ans || exit 0
[[ "$ans" =~ ^[Nn] ]] && exit 0

c64disk --source "$target" "$query" || true
python3 "$BUILD" >/dev/null 2>&1          # re-match the new files

newline="$(awk -F'\t' -v t="$title" '$4 == t {print; exit}' "$INDEX")"
if [[ "$(printf '%s' "$newline" | cut -f2)" == local ]]; then
  echo "Done — launching $title" >&2
  exec c64run "${C64RUN_OPTS[@]}" "$(printf '%s' "$newline" | cut -f3)"
fi

die "download of \"$title\" didn't produce a matching disk (its dump may not match the ranked title).
    Anything fetched is under .../C64/_IA_downloads. Retry with:  c64disk --source $target \"$query\""
