#!/usr/bin/env python3
"""c64menu - master/detail picker for ranked C64 games.

A keyboard-driven list (no fzf). Each game is one master line: marker, title and
an action button.  Expand the selected row (-> / Tab) to reveal a detail line
with the box cover and GameBase64 facts.  Enter is the action button: it plays a
game you own, or downloads-then-plays one you don't.

    o  in your collection   .  Enter plays it (c64run: LOAD"*",8,1 : RUN)
    v  downloadable         .  Enter fetches it (c64disk), then plays it.

Keys:  up/down move . ->/Tab expand . <- collapse . Enter play/get
       type to filter . Backspace edit . Esc clear filter or quit . q quit

Usage:
  c64menu            open the picker
  c64menu -w|-f|-r   pass --warp / --fullscreen / --real through to c64run
  c64menu --refresh  re-pull popularity scores, re-scan availability, rebuild
"""
import os, re, sys, struct, shutil, select, termios, tty, textwrap, subprocess
import importlib.machinery as _m

HERE = os.path.dirname(os.path.abspath(__file__))
INDEX = os.path.join(HERE, "c64_index.tsv")
BUILD = os.path.join(HERE, "build_index.py")
DISK = os.path.join(HERE, "c64disk")
RUN = os.path.join(HERE, "c64run")

# sibling tools, imported as modules (filenames have no .py)
_bi = _m.SourceFileLoader("build_index", os.path.join(HERE, "build_index.py")).load_module()
_cover = _m.SourceFileLoader("bbcover", os.path.join(HERE, "bb-cover")).load_module()
_info = _m.SourceFileLoader("c64info", os.path.join(HERE, "c64info")).load_module()

ESC = "\x1b"
DETAIL_X = 24          # column where detail text starts (cover sits to its left)
COVER_W = 18          # cover width in cells; card height grows to fit the cover
CELL_AR = 0.5         # terminal cell width:height ratio (~1:2) for aspect maths
CARD_MIN = 8          # smallest detail card
HAS_IMG = os.environ.get("TERM_PROGRAM") == "WezTerm" and shutil.which("wezterm")


def die(msg):
    print(f"c64menu: {msg}", file=sys.stderr)
    sys.exit(1)


def py(script, *args):
    return subprocess.run([sys.executable, script, *args])


# --------------------------------------------------------------------------- refresh
def refresh():
    # catalogue IA games that have a cover + GameBase64 details (ranked), then build.
    if py(DISK, "--ia-index").returncode != 0:
        die("could not build the IA catalogue")
    py(BUILD)


# --------------------------------------------------------------------------- data
def load_rows():
    rows = []
    for line in open(INDEX, encoding="utf-8"):
        f = line.rstrip("\n").split("\t")
        if len(f) >= 5:
            rows.append(f)            # display, status, target, title, query
    return rows


def canon_of(row):
    # mirror c64disk.game_title so the cover canon matches the catalogue's canon
    base = re.split(r"[\(\[]", row[4], maxsplit=1)[0]
    base = re.split(r":| - ", base, maxsplit=1)[0]
    base = re.sub(r"\bv\d+(\.\d+)*\b", "", base)
    return _bi.norm(base)


def ia_cover(ident):
    """Fallback cover: the Internet Archive item's own image (services/img), cached."""
    if not ident:
        return None
    cache = os.path.join(_cover.CDIR, "ia_" + re.sub(r"[^A-Za-z0-9_.-]", "_", ident) + ".jpg")
    if os.path.exists(cache) and os.path.getsize(cache) > 0:
        return cache
    try:
        data = _cover.fetch(f"https://archive.org/services/img/{ident}")
        if len(data) < 1000:                  # generic placeholder icon -> treat as none
            return None
        os.makedirs(_cover.CDIR, exist_ok=True)
        open(cache, "wb").write(data)
        return cache
    except Exception:
        return None


def image_size(path):
    """(width, height) in pixels for a PNG or JPEG, without any image library."""
    try:
        with open(path, "rb") as f:
            head = f.read(26)
            if head[:8] == b"\x89PNG\r\n\x1a\n":
                return struct.unpack(">II", head[16:24])
            if head[:2] == b"\xff\xd8":                  # JPEG: walk the segment markers
                f.seek(2)
                while True:
                    b = f.read(1)
                    if not b:
                        break
                    if b != b"\xff":
                        continue
                    m = f.read(1)
                    while m == b"\xff":
                        m = f.read(1)
                    if m and 0xC0 <= m[0] <= 0xCF and m[0] not in (0xC4, 0xC8, 0xCC):
                        f.read(3); h, w = struct.unpack(">HH", f.read(4)); return w, h
                    ln = struct.unpack(">H", f.read(2))[0]
                    f.seek(ln - 2, 1)
    except Exception:
        pass
    return None


def vis_len(s):
    return len(re.sub(r"\x1b\[[0-9;]*m", "", s))


def trunc(s, n):
    return s if len(s) <= n else s[: max(0, n - 1)] + "…"


# --------------------------------------------------------------------------- TUI
class Menu:
    def __init__(self, rows, runopts, cidx):
        self.all = rows
        self.runopts = runopts
        self.cidx = cidx               # cover index (canon -> filename)
        self.filter = ""
        self.sel = 0
        self.top = 0
        self.open = False
        self.con = None                # GB64 db (lazy)
        self.dcache = {}               # query -> (record_or_None, cover_path_or_None)
        self.apply_filter()

    # ---- model
    def apply_filter(self):
        q = self.filter.lower()
        self.rows = [r for r in self.all if q in r[3].lower()] if q else list(self.all)
        self.sel = min(self.sel, max(0, len(self.rows) - 1))
        self.top = 0
        self.open = False

    def detail(self, row):
        """(gb64_record_or_None, cover_path_or_None) for a row, cached."""
        query = row[4]
        if query in self.dcache:
            return self.dcache[query]
        rec = None
        try:
            if self.con is None:
                self.con = _info.open_db()
            gid = _info.best_match(self.con, query)
            if gid is not None:
                rec = _info.record(self.con, gid, note_limit=240)
        except Exception:
            rec = None
        cover = None
        try:
            cover = _cover.ensure_cover(canon_of(row), self.cidx)   # libretro boxart first
        except Exception:
            cover = None
        if not cover:
            cover = ia_cover(row[5] if len(row) > 5 else "")        # else the IA item image
        self.dcache[query] = (rec, cover)
        return self.dcache[query]

    # ---- rendering
    def detail_text(self, row, rec, width, max_lines):
        right = max(10, width - DETAIL_X)
        lines = []
        title = row[3]
        if rec:
            lines.append(f"{ESC}[1m{title}{ESC}[0m" + (f"  ({rec['year']})" if rec["year"] else ""))
            d = dict(rec["rows"])
            for v in (d.get("Genre"),
                      " · ".join(x for x in (d.get("Publisher"), d.get("Developer")) if x),
                      " · ".join(x for x in (d.get("Programmer"),
                                             d.get("Music") and "♪ " + d["Music"]) if x),
                      " · ".join(x for x in (d.get("Players"),
                                             d.get("Rating") and "★" + d["Rating"],
                                             d.get("Classic") and "classic") if x),
                      d.get("Language")):
                if v:
                    lines.append(f"{ESC}[2m{trunc(v, right)}{ESC}[0m")
            if rec["note"] and len(lines) < max_lines - 1:
                lines.append("")
                for w in textwrap.wrap(rec["note"], right)[: max_lines - len(lines)]:
                    lines.append(f"{ESC}[2m{w}{ESC}[0m")
        else:
            lines.append(f"{ESC}[1m{title}{ESC}[0m")
            lines.append(f"{ESC}[2m(no GameBase64 entry){ESC}[0m")
        return lines[:max_lines]

    def card_height(self, cover, body_h):
        """Card tall enough to contain the cover at COVER_W cells, leaving >=3 list rows."""
        need = CARD_MIN
        if cover:
            sz = image_size(cover)
            if sz and sz[0]:
                w, h = sz
                need = max(need, round(COVER_W * (h / w) * CELL_AR) + 1)   # +1 top padding
        return max(CARD_MIN, min(need, body_h - 3))

    def frame(self):
        cols, lines = shutil.get_terminal_size((80, 24))
        body_h = max(3, lines - 2)
        card_h, sel_rec, sel_cover = 0, None, None
        if self.open and self.rows:
            sel_rec, sel_cover = self.detail(self.rows[self.sel])
            card_h = self.card_height(sel_cover, body_h)   # grow the card to fit the cover
        budget = max(1, body_h - card_h)
        if self.sel < self.top:
            self.top = self.sel
        elif self.sel >= self.top + budget:
            self.top = self.sel - budget + 1
        self.top = max(0, min(self.top, max(0, len(self.rows) - budget)))

        have = sum(1 for r in self.all if r[1] == "local")
        getn = sum(1 for r in self.all if r[1] == "available")
        cur = f"{ESC}[7m {self.filter or 'type to filter'} {ESC}[0m"
        header = f"{ESC}[1mC64 ▶{ESC}[0m {cur}   ●{have} here · ⬇{getn} downloadable"

        out = [f"{ESC}[H", header, f"{ESC}[K\r\n"]
        srow = 1                                          # next screen row (0-based)
        img = None
        for i in range(self.top, min(len(self.rows), self.top + budget)):
            row = self.rows[i]
            out.append(self.master_line(row, i, cols)); out.append(f"{ESC}[K\r\n")
            srow += 1
            if self.open and i == self.sel and card_h:
                rec, cover = sel_rec, sel_cover
                dt = self.detail_text(row, rec, cols, card_h - 1)
                if cover and HAS_IMG:
                    # width binds for portrait covers; height-cap is the card interior
                    img = (cover, srow + 1, COVER_W, card_h - 1)
                for k in range(card_h):
                    left = " " * DETAIL_X
                    if not cover and k == 1:
                        left = "   " + f"{ESC}[2m[no cover]{ESC}[0m" + " " * (DETAIL_X - 13)
                    text = dt[k - 1] if 1 <= k <= len(dt) else ""
                    out.append(left + text); out.append(f"{ESC}[K\r\n")
                    srow += 1
        for _ in range(srow, lines - 1):                 # pad to the footer
            out.append(f"{ESC}[K\r\n")
        foot = "↑↓ move · →/Tab expand · ← collapse · ↵ play/get · type to filter · esc quit"
        out.append(f"{ESC}[2m{trunc(foot, cols)}{ESC}[0m{ESC}[K")
        sys.stdout.write("".join(out)); sys.stdout.flush()

        if img:
            cover, irow, cw, ch = img
            subprocess.run(["wezterm", "imgcat", "--position", f"2,{irow}",
                            "--width", str(cw), "--height", str(ch),
                            "--no-move-cursor", cover],
                           stderr=subprocess.DEVNULL)        # inherits real stdout fd
            sys.stdout.flush()

    def master_line(self, row, i, cols):
        display, status = row[0], row[1]
        # strip the leading marker/rank from the index display; we draw our own
        label = re.sub(r"^[●⬇·]\s*", "", display)
        marker = "●" if status == "local" else "⬇"
        caret = "▾" if (self.open and i == self.sel) else ("▸" if i == self.sel else " ")
        if status == "local":
            btn = f"{ESC}[32m↵ Play{ESC}[0m"; btn_w = 6
        else:
            btn = f"{ESC}[33m↵ Get {ESC}[0m"; btn_w = 6
        left = f"{caret} {marker} "
        avail = cols - vis_len(left) - btn_w - 2
        left += trunc(label, max(1, avail))
        pad = max(1, cols - vis_len(left) - btn_w)
        line = left + " " * pad + btn
        if i == self.sel:
            line = f"{ESC}[7m" + re.sub(r"\x1b\[0m", f"{ESC}[0m{ESC}[7m", line) + f"{ESC}[0m"
        return line

    # ---- loop
    def run(self):
        fd = sys.stdin.fileno()
        old = termios.tcgetattr(fd)
        sys.stdout.write(f"{ESC}[?1049h{ESC}[?25l")          # alt screen, hide cursor
        try:
            tty.setraw(fd)
            while True:
                self.frame()
                key = read_key()
                if key in ("q", "ESC"):
                    if key == "ESC" and self.filter:
                        self.filter = ""; self.apply_filter()
                        continue
                    return None
                elif key == "UP":
                    self.sel = max(0, self.sel - 1)
                elif key == "DOWN":
                    self.sel = min(len(self.rows) - 1, self.sel + 1)
                elif key in ("RIGHT", "TAB"):
                    self.open = True
                elif key == "LEFT":
                    self.open = False
                elif key == "ENTER":
                    if self.rows:
                        return self.rows[self.sel]
                elif key == "BACKSPACE":
                    if self.filter:
                        self.filter = self.filter[:-1]; self.apply_filter()
                elif key and len(key) == 1 and 32 <= ord(key) < 127:
                    self.filter += key; self.apply_filter()
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old)
            sys.stdout.write(f"{ESC}[?25h{ESC}[?1049l"); sys.stdout.flush()


def read_key():
    ch = os.read(0, 1)
    if not ch:
        return None
    if ch == b"\x1b":
        r, _, _ = select.select([0], [], [], 0.05)
        if not r:
            return "ESC"
        if os.read(0, 1) == b"[":
            code = os.read(0, 1).decode("latin-1", "ignore")
            return {"A": "UP", "B": "DOWN", "C": "RIGHT", "D": "LEFT"}.get(code, "")
        return "ESC"
    if ch in (b"\r", b"\n"):
        return "ENTER"
    if ch == b"\t":
        return "TAB"
    if ch in (b"\x7f", b"\x08"):
        return "BACKSPACE"
    if ch == b"\x03":
        return "ESC"
    try:
        return ch.decode("utf-8")
    except UnicodeDecodeError:
        return ""


# --------------------------------------------------------------------------- actions
def play(target, runopts):
    os.execv(RUN, [RUN, *runopts, target])


def fetch_and_play(row, runopts):
    title, query = row[3], row[4]
    ident = row[5] if len(row) > 5 else ""
    print(f'Downloading "{title}" from the Internet Archive ...', file=sys.stderr)
    if ident:
        py(DISK, "--id", ident)                 # exact IA item (no guessing by title)
    else:
        py(DISK, "--source", "ia", query)
    py(BUILD)
    for f in load_rows():
        if f[3] == title and f[1] == "local":
            print(f"Done - launching {title}", file=sys.stderr)
            play(f[2], runopts)
    die(f'download of "{title}" produced no matching disk. '
        f'Retry:  c64disk --id {ident}' if ident else
        f'Retry:  c64disk --source ia "{query}"')


def main(argv):
    runopts = []
    i = 0
    while i < len(argv) and argv[i].startswith("-"):
        a = argv[i]
        if a in ("-w", "--warp"):           runopts.append("-w")
        elif a in ("-f", "--fullscreen"):   runopts.append("-f")
        elif a in ("-r", "--real"):         runopts.append("-r")
        elif a == "--refresh":
            refresh()
            if i + 1 >= len(argv):
                return 0
        elif a in ("-h", "--help"):
            print(__doc__); return 0
        else:
            die(f"unknown option: {a} (try --help)")
        i += 1

    if not os.path.exists(INDEX):
        refresh()
    if not os.path.getsize(INDEX):
        die("index is empty (try: c64menu --refresh)")
    if not sys.stdin.isatty():
        die("c64menu needs an interactive terminal")

    try:
        cidx = _cover.load_index()
    except Exception as e:
        die(f"could not load cover index: {e}")
    rows = load_rows()
    if not rows:
        die("no games to show (try: c64menu --refresh)")
    chosen = Menu(rows, runopts, cidx).run()
    if not chosen:
        return 0
    if chosen[1] == "local":
        play(chosen[2], runopts)
    fetch_and_play(chosen, runopts)
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
