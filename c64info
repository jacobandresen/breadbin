#!/usr/bin/env python3
"""c64info - show GameBase64 (GB64) details for a C64 game.

Uses the GameBase64 collection as a local SQLite database (~17MB, 30,000 games).
The DB is downloaded and cached once on first use; everything after is offline.

Source: gamebase64.com  ·  prebuilt SQLite: twinbirds.com/gamebase64browser

Usage:
  c64info <title words>          print GB64 details for the best match
  c64info -a / --all <title>     list every matching game (don't show details)
  c64info --refresh-db           re-download the GB64 SQLite database
"""
import os, re, sys, gzip, sqlite3, subprocess, urllib.request
import importlib.machinery

HERE = os.path.dirname(os.path.abspath(__file__))
bi = importlib.machinery.SourceFileLoader(
    "build_index", os.path.join(HERE, "build_index.py")).load_module()  # norm() / file_key()

DB = os.path.join(HERE, "gb64.sqlitedb")
DB_URL = "http://www.twinbirds.com/gamebase64browser/GBC_v19.sqlitedb.gz"
UA = "breadbin-c64info/1.0 (personal C64 collection tool; polite, low-volume)"

DETAIL_SQL = """
SELECT g.Name, y.Year, pu.Publisher, de.Developer,
       pg.ParentGenre, ge.Genre, pr.Programmer, mu.Musician,
       la.Language, g.PlayersFrom, g.PlayersTo, g.PlayersSim,
       g.Rating, g.Classic, g.Comment, g.MemoText,
       g.WebLink_Name, g.WebLink_URL, g.Filename
FROM Games g
LEFT JOIN Years y        ON y.YE_Id  = g.YE_Id
LEFT JOIN Publishers pu  ON pu.PU_Id = g.PU_Id
LEFT JOIN Developers de  ON de.DE_Id = g.DE_Id
LEFT JOIN Genres ge      ON ge.GE_Id = g.GE_Id
LEFT JOIN PGenres pg     ON pg.PG_Id = ge.PG_Id
LEFT JOIN Programmers pr ON pr.PR_Id = g.PR_Id
LEFT JOIN Musicians mu   ON mu.MU_Id = g.MU_Id
LEFT JOIN Languages la   ON la.LA_Id = g.LA_Id
WHERE g.GA_Id = ?;
"""


def log(*a): print(*a, file=sys.stderr)
def die(msg): log(f"c64info: {msg}"); sys.exit(1)


def _utf8(b):
    try: b.decode("utf-8"); return True
    except UnicodeDecodeError: return False


def ensure_db(refresh=False):
    if refresh:
        try: os.remove(DB)
        except FileNotFoundError: pass
    if os.path.exists(DB) and os.path.getsize(DB) > 0:
        return
    log("downloading GameBase64 SQLite database (~6MB) ...")
    req = urllib.request.Request(DB_URL, headers={"User-Agent": UA})
    with urllib.request.urlopen(req, timeout=120) as r:
        blob = gzip.decompress(r.read())
    open(DB, "wb").write(blob)
    log(f"  cached {len(blob) // (1024 * 1024)}MB -> {DB}")


def search(con, query):
    """Return (matches, exact): all candidates, and the canonical-exact subset.
    Both are ordered best-first (exact title equality, then GB64 Rating desc)."""
    qn = bi.norm(query)
    rows = con.execute(
        "SELECT GA_Id, Name, Rating FROM Games WHERE Name LIKE ? COLLATE NOCASE",
        (f"%{query}%",)).fetchall()
    if not rows:  # fall back to word-by-word (handles punctuation / ordering)
        words = [w for w in re.findall(r"[A-Za-z0-9]+", query) if len(w) > 1]
        if words:
            like = " AND ".join(["Name LIKE ?"] * len(words))
            rows = con.execute(
                f"SELECT GA_Id, Name, Rating FROM Games WHERE {like} COLLATE NOCASE",
                [f"%{w}%" for w in words]).fetchall()

    def rank(r): return -(r[2] or 0)                       # higher GB64 rating first
    exact = sorted((r for r in rows if bi.norm(re.split(r"[\(\[]", r[1], 1)[0]) == qn), key=rank)
    rest = sorted((r for r in rows if r not in exact), key=lambda r: (rank(r), r[1]))
    pairs = lambda rs: [(i, n) for i, n, _ in rs]
    return pairs(exact + rest), pairs(exact)


def pick(matches):
    if len(matches) == 1:
        return matches[0]
    if sys.stdin.isatty() and (fzf := _which("fzf")):
        lines = "\n".join(f"{n}\t{i}" for i, n in matches)
        r = subprocess.run([fzf, "--with-nth=1", "--delimiter=\t", "--reverse",
                            "--prompt", "GB64 > "], input=lines, capture_output=True, text=True)
        out = r.stdout.strip()
        if not out: sys.exit(0)
        gid = int(out.split("\t")[-1])
        return next(m for m in matches if m[0] == gid)
    log(f"{len(matches)} matches - narrow it, or use --all:")
    for _, n in matches[:25]: log(f"  {n}")
    sys.exit(1)


def _which(cmd):
    from shutil import which
    return which(cmd)


def open_db(refresh=False):
    """Connect to the (lazily-downloaded) GB64 DB with lenient text decoding."""
    ensure_db(refresh)
    con = sqlite3.connect(DB)
    # GB64 text is Windows-1252 (the .mdb origin), not UTF-8 -> decode leniently.
    con.text_factory = lambda b: b.decode("utf-8") if _utf8(b) else b.decode("cp1252", "replace")
    return con


def best_match(con, query):
    """Return the GA_Id of the single best match for query, or None."""
    matches, exact = search(con, query)
    if exact:
        return exact[0][0]
    return matches[0][0] if matches else None


def record(con, gid, note_limit=500):
    """Structured GB64 details for one game: {name, year, rows:[(label,val)], note}."""
    (name, year, pub, dev, pgenre, genre, prog, musician, lang,
     pf, pt, psim, rating, classic, comment, memo,
     wl_name, wl_url, filename) = con.execute(DETAIL_SQL, (gid,)).fetchone()

    def clean(v):
        if v in (None, "", "(None)", "(Unknown)", -1, "-1"): return None
        return v

    players = None
    pf, pt = clean(pf), clean(pt)
    if pf or pt:
        players = f"{pf or pt}" if (pf == pt or not pt) else f"{pf}-{pt}"
        if clean(psim): players += " (simultaneous)"
    g = " / ".join(x for x in (clean(pgenre), clean(genre)) if x)
    rating = clean(rating)

    rows = [(lbl, v) for lbl, v in (
        ("Publisher",  clean(pub)),
        ("Developer",  clean(dev)),
        ("Genre",      g or None),
        ("Programmer", clean(prog)),
        ("Music",      clean(musician)),
        ("Language",   clean(lang)),
        ("Players",    players),
        ("Rating",     f"{rating}/5" if rating is not None else None),
        ("Classic",    "yes" if clean(classic) else None),
        ("GB64 file",  clean(filename)),
        ("Link",       clean(wl_url) and f"{clean(wl_name) or ''} {clean(wl_url)}".strip()),
    ) if v is not None]

    note = clean(comment) or clean(memo)
    if note:
        note = re.sub(r"\s+", " ", note).strip()             # memos can be long crack docs
        if note_limit and len(note) > note_limit:
            note = note[:note_limit].rsplit(" ", 1)[0] + " ..."
    return {"name": name, "year": clean(year), "rows": rows, "note": note}


def show(con, gid):
    r = record(con, gid)
    print(f"\n  {r['name']}" + (f"  ({r['year']})" if r["year"] else ""))
    print("  " + "-" * max(len(r["name"]) + 8, 24))
    for label, val in r["rows"]:
        print(f"    {label:<11} {val}")
    if r["note"]:
        print(f"\n    {r['note']}")
    print()


def main(argv):
    refresh, list_all, queries = False, False, []
    i = 0
    while i < len(argv):
        a = argv[i]
        if a == "--refresh-db":       refresh = True
        elif a in ("-a", "--all"):    list_all = True
        elif a in ("-h", "--help"):   print(__doc__); return 0
        elif a.startswith("-"):       die(f"unknown option: {a}")
        else:                         queries.append(a)
        i += 1

    if not queries and not refresh:
        die("give a game title (see --help)")
    con = open_db(refresh)
    if not queries:
        return 0
    query = " ".join(queries)
    matches, exact = search(con, query)
    if not matches:
        die(f'no GB64 game matching: {query}')
    if list_all:
        for _, n in matches: print(n)
        return 0
    # one clear exact title -> just show it; several exact -> best-rated unless on a tty
    if len(exact) == 1 or (exact and not sys.stdin.isatty()):
        if len(exact) > 1:
            log(f'note: {len(exact)} GB64 entries titled like "{query}"; showing the top-rated '
                f'(use --all to see them).')
        gid, _ = exact[0]
    else:
        gid, _ = pick(matches)
    show(con, gid)
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
