#!/usr/bin/env python3
"""c64disk - find and download C64 disk games from multiple archives.

Sources (--source):
  ia     Internet Archive `softwarelibrary_c64` - per-game items, cracked dumps (default)
  tosec  TOSEC C64 set on IA - comprehensive, full-title naming; served from inside the
         zip-of-zips and unpacked locally
  all    try ia first, fall back to tosec when ia can't complete a game

Downloads land in your collection so `c64menu --refresh` picks them up.

Usage:
  c64disk <title> [<title> ...]      search and download the best-matching disk image(s)
  c64disk --source all <title>       try every source
  c64disk --missing                  disk games from the Lemon64 top-100 you don't own
  c64disk -n / --list <title>        dry run: show what would be downloaded
  c64disk --dest DIR                 download dir (default: <collection>/C64/_IA_downloads)
  c64disk --refresh-index            rebuild the cached TOSEC listing

Matching is identical across sources: exact canonical game-title equality (numerals
preserved, so Archon != Archon II) for --missing; fuzzy fzf picker for interactive
queries. Multi-disk games download the whole most-complete release; sources are never
mixed within one game.
"""
import os, re, sys, io, time, json, html, zipfile, difflib, urllib.parse, urllib.request, subprocess

HERE = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, HERE)
from build_index import norm, title_key

COLL      = "softwarelibrary_c64"
SEARCH    = "https://archive.org/advancedsearch.php"
SCRAPE    = "https://archive.org/services/search/v1/scrape"
META      = "https://archive.org/metadata/"
DL        = "https://archive.org/download/"
TOSEC_ID  = "tosec-20161111-commodore-c64"
TOSEC_ZIP = "TOSEC.2016.11.11.Commodore.C64.AlphaBot.zip"
TOSEC_LIST = f"{DL}{TOSEC_ID}/{TOSEC_ZIP}/"
TOSEC_INDEX = os.path.join(HERE, "tosec_index.tsv")
POP       = os.path.join(HERE, "c64_popularity.tsv")
INDEX     = os.path.join(HERE, "c64_index.tsv")
AVAIL     = os.path.join(HERE, "c64_avail.tsv")
IA_INDEX  = os.path.join(HERE, "ia_index.tsv")
COVERS    = os.path.join(HERE, "covers_index.tsv")
DEST_DFLT = os.path.expanduser(os.environ.get("C64_LIB", "~/Games/Commodore/C64") + "/_IA_downloads")
UA        = "c64disk/1.0 (personal C64 collection tool; polite, low-volume)"
EXT_PRIO  = (".d64", ".g64", ".d81", ".d71", ".t64", ".prg", ".crt")
STOP      = {"the", "a", "of", "and", "or", "to", "in", "for"}

def log(*a): print(*a, file=sys.stderr)

def get(url, binary=False):
    req = urllib.request.Request(url, headers={"User-Agent": UA})
    with urllib.request.urlopen(req, timeout=90) as r:
        data = r.read()
    return data if binary else data.decode("utf-8", "replace")

def is_disk(blob):
    return len(blob) >= 1024 and blob.lstrip()[:1] not in (b"<",)

# --- title helpers -----------------------------------------------------------
def game_title(t):
    """The game name only - strip '(year)(publisher)[flags]', subtitle and version."""
    t = re.split(r"\s*[\(\[]", t, maxsplit=1)[0]
    t = re.split(r":| - ", t, maxsplit=1)[0]
    t = re.sub(r"\bv\d+(\.\d+)*\b", "", t)        # strip version (v1.0) - not a distinguishing token
    return norm(t)

def words_of(query):
    return [w for w in re.findall(r"[a-z0-9]+", query.lower()) if w not in STOP] or [query.lower()]

def disk_no(t):
    m = re.search(r"disk\s*(\d+)", t.lower());  return int(m.group(1)) if m else 1

def side_no(t):
    m = re.search(r"side\s*([a-d1-4])", t.lower())
    if not m: return 0
    g = m.group(1)
    return int(g) if g.isdigit() else (ord(g) - ord("a") + 1)

def release_key(t):
    t = t.lower()
    t = re.sub(r"disk\s*\d+\s*(of\s*\d+)?", "", t)
    t = re.sub(r"side\s*[a-d0-9]\b", "", t)
    t = re.sub(r"\b(boot|game|player\s*disk|scenario|data\s*disk|doc)\b", "", t)
    t = re.sub(r"[\(\)\[\]]", " ", t)
    return re.sub(r"\s+", " ", t).strip()

def has_boot(members):
    """True if the release includes a bootable first disk (disk 1 side A / single side / 'Boot')."""
    return any(("boot" in t.lower()) or (disk_no(t) == 1 and side_no(t) in (0, 1))
               for _, t in members)

def best_release(items):
    """Members of the best release (same source): bootable first, then most disks."""
    groups = {}
    for it in items:
        groups.setdefault(release_key(it[1]), []).append(it)
    def cov(g): return len({disk_no(t) for _, t in g})
    _, members = max(groups.items(),
        key=lambda kv: (has_boot(kv[1]),                                  # must be able to boot
                        cov(kv[1]),                                       # most distinct disks
                        -sum(t.count("[") for _, t in kv[1]),            # fewest crack/tool tags
                        -len(kv[0])))                                     # shorter = cleaner
    members.sort(key=lambda it: (disk_no(it[1]), side_no(it[1])))
    return members

def coverage(members):
    want = max((int(m.group(1)) for _, t in members
                for m in [re.search(r"of\s*(\d+)", t.lower())] if m), default=1)
    return len({disk_no(t) for _, t in members}), want

# --- source: Internet Archive softwarelibrary_c64 ----------------------------
def search_ia(query):
    q = f"collection:({COLL}) AND title:({' OR '.join(words_of(query))})"
    url = (SEARCH + "?" + urllib.parse.urlencode({"q": q, "rows": "80", "output": "json"})
           + "&fl[]=identifier&fl[]=title")
    docs = json.loads(get(url))["response"]["docs"]
    return [(("ia", d["identifier"]), d.get("title", d["identifier"])) for d in docs]

def download_ia(identifier, title, dest, dry):
    files = json.loads(get(META + identifier)).get("files", [])
    names = [f["name"] for f in files]
    fnames = next((sorted(n for n in names if n.lower().endswith(e))
                   for e in EXT_PRIO if any(n.lower().endswith(e) for n in names)), [])
    got = []
    for fname in fnames:
        out = os.path.join(dest, fname)
        if dry:                                   log(f"    would download: {fname}"); got.append(fname); continue
        if os.path.exists(out) and os.path.getsize(out) > 0:
            log(f"    exists, skip: {fname}"); got.append(fname); continue
        data = get(DL + identifier + "/" + urllib.parse.quote(fname), binary=True)
        if not is_disk(data):
            log(f"    !! not a disk image ({len(data)}B) - skipped: {fname}"); continue
        os.makedirs(dest, exist_ok=True); open(out, "wb").write(data)
        log(f"    saved: {fname} ({len(data)//1024} KB)"); got.append(fname); time.sleep(1)
    return got

# --- source: TOSEC (zip-of-zips on IA, unpacked locally) ---------------------
def build_tosec_index():
    log("building TOSEC index (one-time ~170MB listing) ...")
    page = get(TOSEC_LIST)
    best = {}   # title -> url, preferring D64 over G64
    for href in re.findall(r'href="(//archive\.org/download/[^"]+\.zip)"', page):
        is_d64 = "%5BD64%5D" in href
        if "Games" not in href or not (is_d64 or "%5BG64%5D" in href):
            continue
        title = urllib.parse.unquote(html.unescape(href.split("%2F")[-1]))[:-4]  # strip .zip
        if title not in best or (is_d64 and "%5BG64%5D" in best[title]):
            best[title] = "https:" + href
    with open(TOSEC_INDEX, "w", encoding="utf-8") as f:
        for t, u in sorted(best.items()): f.write(f"{t}\t{u}\n")
    log(f"  TOSEC index: {len(best)} D64/G64 game disks cached")

def tosec_entries():
    if not os.path.exists(TOSEC_INDEX): build_tosec_index()
    return [tuple(l.rstrip("\n").split("\t", 1)) for l in open(TOSEC_INDEX, encoding="utf-8")]

def search_tosec(query):
    ws = words_of(query)
    return [(("tosec", u), t) for t, u in tosec_entries() if any(w in game_title(t) for w in ws)]

def download_tosec(url, title, dest, dry):
    fname0 = (title + ".d64").replace("/", "-")          # provisional, for dry/log
    if dry:
        log(f"    would download: {title}.zip -> unpack"); return [fname0]
    data = get(url, binary=True)
    try:
        z = zipfile.ZipFile(io.BytesIO(data))
    except Exception as e:
        log(f"    !! bad TOSEC zip: {e}"); return []
    member = next((sorted((n for n in z.namelist() if n.lower().endswith(e)), key=len)[0]
                   for e in EXT_PRIO if any(n.lower().endswith(e) for n in z.namelist())), None)
    if not member:
        log("    (no disk image in TOSEC zip)"); return []
    fname = (title + os.path.splitext(member)[1]).replace("/", "-")   # save under TOSEC title
    out = os.path.join(dest, fname)
    if os.path.exists(out) and os.path.getsize(out) > 0:
        log(f"    exists, skip: {fname}"); return [fname]
    blob = z.read(member)
    if not is_disk(blob):
        log(f"    !! not a disk image - skipped: {fname}"); return []
    os.makedirs(dest, exist_ok=True); open(out, "wb").write(blob)
    log(f"    saved: {fname} ({len(blob)//1024} KB)"); time.sleep(1)
    return [fname]

SEARCHERS = {"ia": search_ia, "tosec": search_tosec}

def download(handle, title, dest, dry):
    src, ref = handle
    return download_tosec(ref, title, dest, dry) if src == "tosec" else download_ia(ref, title, dest, dry)

# --- matching ----------------------------------------------------------------
def _have(cmd): return subprocess.run(["which", cmd], capture_output=True).returncode == 0

def pick_with_fzf(matches):
    if not sys.stdin.isatty() or not _have("fzf"):
        return None
    lines = "\n".join(f"{t}\t{idx}" for idx, (h, t) in enumerate(matches))
    r = subprocess.run(["fzf", "--with-nth=1", "--delimiter=\t", "--reverse",
                        "--prompt", "disk > "], input=lines, capture_output=True, text=True)
    out = r.stdout.strip()
    if not out: return []
    return [matches[int(out.split("\t")[-1])]]

def resolve(query, strict, source):
    """[(handle, title)] for one source: exact canonical equality, else fuzzy fzf."""
    qn = norm(query)
    if not qn: return []
    try:
        results = SEARCHERS[source](query)
    except Exception as e:
        log(f'  {source} search error for "{query}": {e}'); return []

    exact = [(h, t) for h, t in results if game_title(t) == qn]
    if exact:
        return best_release(exact)
    if strict:
        return []

    scored = sorted(((difflib.SequenceMatcher(None, qn, game_title(t)).ratio(), h, t)
                     for h, t in results), key=lambda x: x[0], reverse=True)
    pool = [(h, t) for r, h, t in scored if r >= 0.45][:20]
    if not pool: return []
    chosen = pool[0:1] if len(pool) == 1 else pick_with_fzf(pool)
    if chosen is None:
        log(f'  "{query}": {len(pool)} fuzzy matches in {source} - run on a terminal to pick:')
        for h, t in pool[:15]: log("     " + t)
        return []
    if not chosen: return []
    cg = game_title(chosen[0][1])
    return best_release([(h, t) for h, t in results if game_title(t) == cg])

def resolve_best(query, strict, sources):
    """Try sources in order; never mix. Strict: keep the most disk-complete; stop
    as soon as a source yields a complete set. Interactive: first source that hits."""
    best, best_cov = None, -1
    for s in sources:
        r = resolve(query, strict, s)
        if not r: continue
        if not strict:
            return r
        cov, want = coverage(r)
        if cov > best_cov: best, best_cov = r, cov
        if cov >= want: return r
    return best

def missing_titles():
    # not-owned ranked games: read from the popularity list so a scan works even
    # when the index has already been filtered to only-findable entries.
    owned = set()
    for l in open(INDEX, encoding="utf-8"):
        f = l.rstrip("\n").split("\t")
        if len(f) >= 5 and f[1] == "local":
            owned.add(f[3])
    out = []
    for l in open(POP, encoding="utf-8"):
        _, _, _, title = l.rstrip("\n").split("\t")
        if title not in owned:
            out.append(re.split(r":| - ", title, maxsplit=1)[0])
    return out

def gb64_ratings():
    """Canon -> GameBase64 Rating (0-5). Presence also proves the game has details."""
    info = __import__("importlib").machinery.SourceFileLoader(
        "c64info", os.path.join(HERE, "c64info")).load_module()
    con = info.open_db()
    out = {}
    for name, rating in con.execute("SELECT Name, Rating FROM Games"):
        if not name:
            continue
        c = game_title(name)
        r = rating if isinstance(rating, int) and rating > 0 else 0
        if c and (c not in out or r > out[c]):
            out[c] = r
    return out


def build_ia_index():
    """Catalogue C64 games on the Internet Archive that have GameBase64 details
    -> ia_index.tsv (canon<TAB>rating<TAB>downloads<TAB>identifier<TAB>title),
    ranked by popularity (GB64 rating, then IA download count). Covers come from
    the libretro set when available, else the IA item's own image (services/img),
    so every catalogued game has a cover."""
    log("loading GameBase64 ratings ...")
    ratings = gb64_ratings()
    keep = set(ratings)
    log(f"games with details: {len(keep)}  ·  scanning IA collection ({COLL}) ...")
    best, seen, cursor = {}, 0, None     # canon -> (downloads, title, identifier), most-downloaded wins
    while True:
        params = {"q": f"collection:{COLL}", "fields": "title,identifier,downloads", "count": 10000}
        if cursor: params["cursor"] = cursor
        d = json.loads(get(SCRAPE + "?" + urllib.parse.urlencode(params)))
        items = d.get("items", [])
        if not items: break
        for it in items:
            seen += 1
            ident = it.get("identifier", "")
            title = it.get("title") or ident
            c = game_title(title)
            if c in keep:
                disp = re.sub(r"\s+", " ", re.split(r"[\(\[]", title, 1)[0]).strip()
                dls = int(it.get("downloads") or 0)
                if c not in best or dls > best[c][0]:
                    best[c] = (dls, disp, ident)
        cursor = d.get("cursor")
        if not cursor: break
    rows = [(c, ratings.get(c, 0), dl, ident, disp) for c, (dl, disp, ident) in best.items()]
    rows.sort(key=lambda r: (r[1], r[2]), reverse=True)        # rating, then IA downloads
    with open(IA_INDEX, "w", encoding="utf-8") as f:
        for c, r, dl, ident, disp in rows:
            f.write(f"{c}\t{r}\t{dl}\t{ident}\t{disp}\n")
    log(f"scanned {seen} IA items; {len(rows)} games on IA with details -> {IA_INDEX}")
    return 0


def scan_missing(sources):
    """For each not-owned ranked game, record whether it's downloadable and from
    where -> c64_avail.tsv (query<TAB>source). Network-heavy; run on refresh."""
    titles = missing_titles()
    log(f"scanning {len(titles)} missing titles across {'+'.join(sources)} ...")
    rows = []
    for t in titles:
        r = resolve_best(t, True, sources)
        if r:
            src = r[0][0][0]
            rows.append((t, src)); log(f"  + {t}  [{src}]")
        else:
            log(f"  - {t}")
    with open(AVAIL, "w", encoding="utf-8") as f:
        for t, s in rows: f.write(f"{t}\t{s}\n")
    log(f"available to download: {len(rows)} of {len(titles)} -> {AVAIL}")

def main(argv):
    dry = use_missing = scan = src_set = False
    dest, sources, queries, ident = DEST_DFLT, ["ia"], [], None
    i = 0
    while i < len(argv):
        a = argv[i]
        if a in ("-n", "--list"):     dry = True
        elif a == "--missing":        use_missing = True
        elif a == "--scan-missing":   scan = True
        elif a == "--ia-index":       return build_ia_index()
        elif a == "--id":             i += 1; ident = argv[i]   # download an exact IA item
        elif a == "--dest":           i += 1; dest = argv[i]
        elif a == "--source":         i += 1; sources = ["ia", "tosec"] if argv[i] == "all" else [argv[i]]; src_set = True
        elif a == "--refresh-index":
            try: os.remove(TOSEC_INDEX)
            except FileNotFoundError: pass
        elif a in ("-h", "--help"):   print(__doc__); return 0
        elif a.startswith("-"):       log(f"unknown option: {a}"); return 2
        else:                         queries.append(a)
        i += 1

    bad = [s for s in sources if s not in SEARCHERS]
    if bad: log(f"unknown source(s): {', '.join(bad)} (use ia, tosec, or all)"); return 2

    if scan:
        scan_missing(sources if src_set else ["ia", "tosec"])
        return 0
    if ident:
        log(f"downloading IA item {ident} -> {dest}")
        got = download_ia(ident, ident, dest, dry)
        log(f"\n{'would download' if dry else 'downloaded'} {len(got)} disk image(s).")
        return 0 if got else 1
    if not use_missing and not queries:
        log("nothing to do: give a title, or --missing (see --help)"); return 2

    games = []
    if use_missing:
        for t in missing_titles():
            r = resolve_best(t, True, sources)
            if r: games.append((t, r))
        log(f"missing top-100 disk games found ({'+'.join(sources)}): {len(games)}")
    for q in queries:
        r = resolve_best(q, False, sources)
        if r: games.append((q, r))

    if not games:
        log("nothing matched to download."); return 1

    log(f"\n{'(dry run) ' if dry else ''}processing {len(games)} game(s) -> {dest}\n")
    total = 0
    for label, members in games:
        log(f"* {label}  [{members[0][0][0]}]")
        files = []
        for handle, ti in members:
            files += download(handle, ti, dest, dry)
        total += len(files)
        fs = [f.replace("_", " ") for f in files]
        want = max((int(m.group(1)) for f in fs
                    for m in [re.search(r"of\s*(\d+)", f.lower())] if m), default=1)
        got = len({disk_no(f) for f in fs}) or len(files)
        note = f"{got}/{want} disk(s)" + ("" if got >= want
                                          else f"  ⚠ incomplete - only {got} of {want} found")
        log(f"    -> {note}")
    log(f"\n{'would download' if dry else 'downloaded'} {total} disk image(s) for {len(games)} game(s).")
    if total and not dry:
        log("run  c64menu --refresh  to add them to the picker.")
    return 0

if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
