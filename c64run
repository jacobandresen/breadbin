#!/usr/bin/env python3
"""c64run - boot a Commodore 64 game straight into the emulator, no launcher GUI.

Auto-picks a VICE emulator, preferring a LICENSE-FREE one (no C64 Forever needed):
  1. native x64sc / x64 on PATH         (free VICE, its own bundled ROMs)
  2. the net.sf.VICE flatpak            (free VICE, bundled ROMs)
  3. Cloanto C64 Forever's x64.exe (wine, needs the license)  - fallback only
Override with  C64_EMU="..."  (e.g. C64_EMU='x64' or a full flatpak command).
VICE's -autostart is the emulator equivalent of typing  LOAD"*",8,1  then  RUN .

Defaults: fullscreen, and warp (fast-load) until the game has started.

Usage:
  c64run <game-file>             launch an exact .d64/.tap/.crt/.t64/.prg ...
  c64run <search words>          search your collection, launch the match
  c64run -r <search words>       -r / --real    : true drive emulation (realistic, slower load)
  c64run --no-warp <search>      load at normal speed (don't fast-load to the game)
  c64run --windowed <search>     run in a window instead of fullscreen
  c64run -l <search words>       -l / --list    : just list matches, don't launch
  (-w / --warp and -f / --fullscreen are accepted too, but are now the default)
"""
import os, re, sys, shlex, shutil, subprocess

WINE_X64 = "/opt/wine/.wine/drive_c/Program Files (x86)/Cloanto/C64 Forever/VICE/x64.exe"

# Where your games live.  Override the root with  C64_LIB="/path/to/c64".
LIB_DIRS = [
    os.path.expanduser(os.environ.get("C64_LIB", "~/Games/Commodore/C64")),
]

# Recognised C64 image types.
EXTS = (".d64", ".d71", ".d81", ".t64", ".tap", ".prg", ".crt", ".g64", ".nib", ".p00", ".x64")


def die(msg):
    print(f"c64run: {msg}", file=sys.stderr)
    sys.exit(1)


def pick_emulator():
    """Return the emulator command as an argv list (license-free first)."""
    env = os.environ.get("C64_EMU")
    if env:
        return shlex.split(env)
    for exe in ("x64sc", "x64"):
        if shutil.which(exe):
            return [exe]
    if shutil.which("flatpak"):
        if subprocess.run(["flatpak", "info", "net.sf.VICE"],
                          stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0:
            return ["flatpak", "run", "--command=x64sc", "net.sf.VICE"]
    if os.access(WINE_X64, os.X_OK):
        os.environ.setdefault("WINEPREFIX", "/opt/wine/.wine")
        os.environ.setdefault("WINEDEBUG", "-all")
        return ["wine", WINE_X64]
    die("no VICE found - install 'vice', the net.sf.VICE flatpak, or C64 Forever")


def find_matches(query):
    out = []
    ql = query.lower()
    for root in LIB_DIRS:
        for dirpath, _, files in os.walk(root):
            for name in files:
                if name.lower().endswith(EXTS) and ql in name.lower():
                    out.append(os.path.join(dirpath, name))
    return sorted(out)


def choose(matches, query):
    """Resolve multiple matches: interactive numbered pick on a tty, else bail."""
    print(f'Multiple matches for "{query}":', file=sys.stderr)
    if not sys.stdin.isatty():
        for m in matches:
            print(f"  {m}", file=sys.stderr)
        die("be more specific, or pass the full path")
    for i, m in enumerate(matches, 1):
        print(f"  {i}) {m}", file=sys.stderr)
    while True:
        try:
            sel = input("# ? ")
        except EOFError:
            sys.exit(0)
        if sel.isdigit() and 1 <= int(sel) <= len(matches):
            return matches[int(sel) - 1]


def main(argv):
    warp, real, fullscreen, list_only = True, False, True, False
    args = []
    i = 0
    while i < len(argv):
        a = argv[i]
        if a in ("-w", "--warp"):           warp = True          # default; back-compat
        elif a in ("-W", "--no-warp"):      warp = False
        elif a in ("-r", "--real"):         real = True
        elif a in ("-f", "--fullscreen"):   fullscreen = True    # default; back-compat
        elif a == "--windowed":             fullscreen = False
        elif a in ("-l", "--list"):         list_only = True
        elif a in ("-h", "--help"):         print(__doc__); return 0
        elif a == "--":                     args.extend(argv[i + 1:]); break
        elif a.startswith("-"):             die(f"unknown option: {a} (try --help)")
        else:                               args.append(a)
        i += 1

    if not args:
        die("give a game file or search words (try --help)")

    if len(args) == 1 and os.path.isfile(args[0]):
        game = args[0]
    else:
        query = " ".join(args)
        matches = find_matches(query)
        if not matches:
            die(f"no game matching: {query}")
        elif list_only:
            print("\n".join(matches)); return 0
        elif len(matches) == 1:
            game = matches[0]
        else:
            game = choose(matches, query)

    emu = pick_emulator()
    opts = []
    if warp:        opts.append("-autostart-warp")       # fast-load, then normal speed
    if fullscreen:  opts.append("-VICIIfull")            # VIC-II (C64) fullscreen
    if real:        opts.append("-autostart-handle-tde")  # accurate (slow) drive loading

    print(f'LOAD"*",8,1 : RUN   ->  {os.path.basename(game)}   [{os.path.basename(emu[0])}]',
          file=sys.stderr)
    cmd = emu + opts + ["-autostart", game]
    os.execvp(cmd[0], cmd)


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
