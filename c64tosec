#!/usr/bin/env python3
"""c64tosec - browse the whole TOSEC C64 catalogue, download + play on selection.

Opens an fzf menu of every game in the TOSEC set (one row per game). Selecting one
downloads its complete release via c64disk's TOSEC source and launches it. The game
lands in your collection, so it also shows up in `breadbin menu` afterwards.

Usage:
  c64tosec [-w] [-f] [-r]      browse + play   (flags pass through to c64run)
  c64tosec --refresh-index     rebuild the cached TOSEC listing first
"""
import os, re, sys, subprocess, importlib.machinery

HERE  = os.path.dirname(os.path.abspath(__file__))
INDEX = os.path.join(HERE, "c64_index.tsv")
cd = importlib.machinery.SourceFileLoader("c64disk", os.path.join(HERE, "c64disk")).load_module()

def log(*a): print(*a, file=sys.stderr)

def main(argv):
    runopts = []
    for a in argv:
        if a in ("-w", "--warp"):        runopts.append("-w")
        elif a in ("-f", "--fullscreen"): runopts.append("-f")
        elif a in ("-r", "--real"):       runopts.append("-r")
        elif a == "--refresh-index":
            try: os.remove(cd.TOSEC_INDEX)
            except FileNotFoundError: pass
        elif a in ("-h", "--help"):       print(__doc__); return 0
        else: log(f"unknown option: {a}"); return 2

    if not cd._have("fzf"):
        log("fzf not found"); return 2

    entries = cd.tosec_entries()                      # [(title, url)], builds index if needed

    # one row per game (collapse disk-sides/cracks); keep the cleanest title to display
    best = {}
    for title, url in entries:
        g = cd.game_title(title)
        if not g: continue
        cur = best.get(g)
        if cur is None or (title.count("["), len(title)) < (cur.count("["), len(cur)):
            best[g] = title
    log(f"TOSEC: {len(best)} games")

    lines = "\n".join(f"{disp}\t{g}" for g, disp in sorted(best.items(), key=lambda kv: kv[1].lower()))
    r = subprocess.run(["fzf", "--with-nth=1", "--delimiter=\t", "--reverse", "--cycle",
                        "--prompt", "TOSEC ▶ ",
                        "--header", f"{len(best)} TOSEC games · type to filter · Enter to download + play",
                        "--preview", f"'{HERE}/bb-cover' {{}}",
                        "--preview-window", "right,40%,border-left"],
                       input=lines, capture_output=True, text=True)
    out = r.stdout.strip()
    if not out: return 0
    disp, canon = out.split("\t")[0], out.split("\t")[-1]

    # gather the full, most-complete release for this exact game (canon match - no fuzzy)
    members = cd.best_release([(("tosec", u), t) for (t, u) in entries if cd.game_title(t) == canon])
    if not members:
        log("no disk image found for that game"); return 1

    log(f"* {disp}")
    files = []
    for h, t in members:
        files += cd.download(h, t, cd.DEST_DFLT, dry=False)
    if not files:
        log("download failed"); return 1

    # rebuild so (a) breadbin menu sees it and (b) we boot the same disk the menu would
    subprocess.run([sys.executable, os.path.join(HERE, "build_index.py")], check=False)

    dlset = {os.path.join(cd.DEST_DFLT, f) for f in files}
    boot = None
    for l in open(INDEX, encoding="utf-8"):
        f = l.rstrip("\n").split("\t")
        if len(f) >= 3 and f[1] == "local" and f[2] in dlset:
            boot = f[2]; break
    if not boot:                                       # fallback: lowest disk/side downloaded
        boot = os.path.join(cd.DEST_DFLT,
                            min(files, key=lambda n: (cd.disk_no(n.replace("_", " ")),
                                                      cd.side_no(n.replace("_", " ")))))
    log(f"launching: {os.path.basename(boot)}")
    os.execvp("c64run", ["c64run", *runopts, boot])

if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
