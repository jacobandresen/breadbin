#!/usr/bin/env python3
"""c64kiosk - a grid "kiosk" of C64 game cards: cover on top, details below.

Lays out as many cards per row as the terminal is wide. Move with the arrow keys;
Enter downloads the game (if you don't own it yet) and plays it, or just plays it
if it's already in your collection. Type to filter, Esc/q to quit.

Usage:
  c64kiosk            open the kiosk
  c64kiosk -w|-f|-r   pass --warp / --fullscreen / --real through to c64run
"""
import os, sys, re, shutil, termios, tty, subprocess
import importlib.machinery as _m

HERE = os.path.dirname(os.path.abspath(__file__))
cm = _m.SourceFileLoader("c64menu", os.path.join(HERE, "c64menu")).load_module()  # reuse helpers
ESC = cm.ESC

# fixed card geometry (cells) so the grid is uniform; covers fit inside the box
COVER_CW, COVER_CH = 16, 9        # cover image box
PAD_X, TEXT_H = 2, 3              # gutter between cards; text lines under a cover
CARD_W = COVER_CW + PAD_X
CARD_H = COVER_CH + TEXT_H + 1


def cover_for(row, cidx):
    cover = None
    try:
        cover = cm._cover.ensure_cover(cm.canon_of(row), cidx)        # libretro boxart
    except Exception:
        cover = None
    if not cover:
        cover = cm.ia_cover(row[5] if len(row) > 5 else "")           # else IA item image
    return cover


class Kiosk:
    def __init__(self, rows, runopts, cidx):
        self.all = rows
        self.runopts = runopts
        self.cidx = cidx
        self.filter = ""
        self.sel = 0
        self.top = 0                  # first visible grid row
        self.rows = list(rows)

    def apply_filter(self):
        q = self.filter.lower()
        self.rows = [r for r in self.all if q in r[3].lower()] if q else list(self.all)
        self.sel = self.top = 0

    def grid(self, cols_term, lines_term):
        cols = max(1, cols_term // CARD_W)
        vis_rows = max(1, (lines_term - 1) // CARD_H)
        return cols, vis_rows

    def frame(self):
        cols_term, lines_term = shutil.get_terminal_size((80, 24))
        cols, vis_rows = self.grid(cols_term, lines_term)
        n = len(self.rows)
        sel_row = self.sel // cols if cols else 0
        if sel_row < self.top:
            self.top = sel_row
        elif sel_row >= self.top + vis_rows:
            self.top = sel_row - vis_rows + 1

        have = sum(1 for r in self.all if r[1] == "local")
        cur = f"{ESC}[7m {self.filter or 'type to filter'} {ESC}[0m"
        header = (f"{ESC}[1mC64 kiosk{ESC}[0m {cur}   {n} games · ●{have} here   "
                  f"{ESC}[2m↵ play/get · esc quit{ESC}[0m")

        out = [f"{ESC}[2J{ESC}[H", header]
        imgs = []
        for r in range(vis_rows):
            for c in range(cols):
                idx = (self.top + r) * cols + c
                if idx >= n:
                    continue
                row = self.rows[idx]
                x = 1 + c * CARD_W                      # 1-based screen column
                y = 2 + r * CARD_H                      # 1-based screen row
                sel = (idx == self.sel)
                cover = cover_for(row, self.cidx)
                if cover and cm.HAS_IMG:
                    imgs.append((cover, x - 1, y - 1))  # imgcat is 0-based
                elif not cover:
                    out.append(f"{ESC}[{y + COVER_CH // 2};{x}H{ESC}[2m[no cover]{ESC}[0m")
                out += self.card_text(row, x, y + COVER_CH, sel)
        sys.stdout.write("".join(out)); sys.stdout.flush()

        for cover, x0, y0 in imgs:
            subprocess.run(["wezterm", "imgcat", "--position", f"{x0},{y0}",
                            "--width", str(COVER_CW), "--height", str(COVER_CH),
                            "--no-move-cursor", cover], stderr=subprocess.DEVNULL)
        sys.stdout.flush()

    def card_text(self, row, x, y, sel):
        w = CARD_W - 1
        title = cm.trunc(re.sub(r"\s+★\d+\s*$", "", row[3]), w)
        genre = cm.trunc(row[6] if len(row) > 6 and row[6] else "", w)
        m = re.search(r"★(\d)", row[0])
        mark = "●" if row[1] == "local" else "⬇"
        rating = (f"★{m.group(1)} " if m else "") + mark
        tline = f"{ESC}[7m{title}{ESC}[0m" if sel else f"{ESC}[1m{title}{ESC}[0m"
        return [f"{ESC}[{y};{x}H{tline}",
                f"{ESC}[{y + 1};{x}H{ESC}[2m{genre}{ESC}[0m",
                f"{ESC}[{y + 2};{x}H{rating}"]

    def run(self):
        fd = sys.stdin.fileno()
        old = termios.tcgetattr(fd)
        sys.stdout.write(f"{ESC}[?1049h{ESC}[?25l")
        try:
            tty.setraw(fd)
            while True:
                self.frame()
                cols, _ = self.grid(*shutil.get_terminal_size((80, 24)))
                key = cm.read_key()
                n = len(self.rows)
                if key in ("q", "ESC"):
                    if key == "ESC" and self.filter:
                        self.filter = ""; self.apply_filter(); continue
                    return None
                elif key == "LEFT":
                    self.sel = max(0, self.sel - 1)
                elif key == "RIGHT":
                    self.sel = min(n - 1, self.sel + 1)
                elif key == "UP":
                    self.sel = max(0, self.sel - cols)
                elif key == "DOWN":
                    self.sel = min(n - 1, self.sel + cols)
                elif key == "ENTER":
                    if self.rows:
                        return self.rows[self.sel]
                elif key == "BACKSPACE":
                    if self.filter:
                        self.filter = self.filter[:-1]; self.apply_filter()
                elif key and len(key) == 1 and 32 <= ord(key) < 127:
                    self.filter += key; self.apply_filter()
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old)
            sys.stdout.write(f"{ESC}[?25h{ESC}[?1049l"); sys.stdout.flush()


def main(argv):
    runopts = []
    for a in argv:
        if a in ("-w", "--warp"):           runopts.append("-w")
        elif a in ("-f", "--fullscreen"):   runopts.append("-f")
        elif a in ("-r", "--real"):         runopts.append("-r")
        elif a in ("-h", "--help"):         print(__doc__); return 0
        else:                               cm.die(f"unknown option: {a} (try --help)")

    if not os.path.exists(cm.INDEX) or not os.path.getsize(cm.INDEX):
        cm.die("index is empty (try: c64menu --refresh)")
    if not sys.stdin.isatty():
        cm.die("c64kiosk needs an interactive terminal")

    cidx = cm._cover.load_index()
    rows = cm.load_rows()
    if not rows:
        cm.die("no games to show (try: c64menu --refresh)")
    chosen = Kiosk(rows, runopts, cidx).run()
    if not chosen:
        return 0
    if chosen[1] == "local":
        cm.play(chosen[2], runopts)
    cm.fetch_and_play(chosen, runopts)
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
