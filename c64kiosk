#!/usr/bin/env python3
"""c64kiosk - a cover "kiosk" for C64 games, organised by genre.

Opens on a genre overview: each genre shows its title and the top 3 covers.
  · click a cover  -> download (if needed) and play that game
  · click a genre title -> expand the genre into a full grid of its covers
In an expanded genre, click any cover to play; Esc returns to the overview.
Arrow keys move the focus, Enter activates, q quits.

Usage:
  c64kiosk            open the kiosk
  c64kiosk -w|-f|-r   pass --warp / --fullscreen / --real through to c64run
"""
import os, sys, shutil, termios, tty, subprocess
import importlib.machinery as _m

HERE = os.path.dirname(os.path.abspath(__file__))
cm = _m.SourceFileLoader("c64menu", os.path.join(HERE, "c64menu")).load_module()  # reuse helpers
ESC = cm.ESC
GENRE_OTHER = cm.GENRE_OTHER

PAD_X = 2                         # gutter between cards
# size targets; the grid stretches cards to fill the screen around these
TARGET_CW, TARGET_CH = 22, 16     # expanded-genre card
OV_SECTION = 12                   # overview: rows per genre section (tall covers)
TITLE_H = 3                       # overview: height of the clickable genre bar
AR_REP = 0.6                      # typical cover aspect (cells tall per wide), for sizing


def cover_for(row, cidx):
    cover = None
    try:
        cover = cm._cover.ensure_cover(cm.canon_of(row), cidx)        # libretro boxart
    except Exception:
        cover = None
    if not cover:
        cover = cm.ia_cover(row[5] if len(row) > 5 else "")           # else IA item image
    return cover


def fit_cover(cover, cell, box_w, box_h):
    """(w, h) cells that fit the cover inside box_w x box_h, preserving aspect."""
    sz = cm.image_size(cover)
    if not sz or not sz[0] or not sz[1]:
        return box_w, box_h
    iw, ih = sz
    cwpx, chpx = cell
    ar = (ih / iw) * (cwpx / chpx)
    w, h = box_w, round(box_w * ar)
    if h > box_h:
        h = box_h; w = max(1, round(h / ar))
    return max(1, w), max(1, h)


def focus_frame(x, y, fw, fh):
    """A bright box-drawing frame so the focused card is obvious."""
    c = f"{ESC}[1;93m"
    top = f"{ESC}[{y};{x}H{c}┏{'━' * (fw - 2)}┓{ESC}[0m"
    bot = f"{ESC}[{y + fh - 1};{x}H{c}┗{'━' * (fw - 2)}┛{ESC}[0m"
    sides = "".join(f"{ESC}[{y + i};{x}H{c}┃{ESC}[0m{ESC}[{y + i};{x + fw - 1}H{c}┃{ESC}[0m"
                    for i in range(1, fh - 1))
    return top + sides + bot


def draw_cover(out, imgs, cover, x, y, fw, fh, cell, focused):
    """Queue a cover image inside a (fw x fh) frame at 1-based (x, y); frame if focused."""
    if cover and cm.HAS_IMG:
        w, h = fit_cover(cover, cell, fw - 2, fh - 2)
        imgs.append((cover, x, y, w, h))                  # image at cell (x+1, y+1) -> 0-based (x, y)
    elif not cover:
        out.append(f"{ESC}[{y + fh // 2};{x + 2}H{ESC}[2m[no cover]{ESC}[0m")
    if focused:
        out.append(focus_frame(x, y, fw, fh))


class Kiosk:
    def genre_bar(self, genre, cnt, base, cols_term, focused=False, hint=""):
        """Return a formatted genre title bar line.
        genre: genre string
        cnt: number of games
        base: starting row (1-indexed) for this genre section
        cols_term: terminal width
        focused: whether this genre is currently selected
        hint: optional trailing hint text
        """
        # Build the text content
        name = " ".join(genre.upper())
        txt = f" {name} ({cnt}) {hint}".ljust(cols_term)[:cols_term]
        # Color: focused uses reverse video or bright background
        if focused:
            bar = f"{ESC}[1;97;44m{txt}{ESC}[0m"
        else:
            bar = f"{ESC}[1;97;44m{txt}{ESC}[0m"
        # Position cursor at the base row
        return f"{ESC}[{base};1H{bar}"
    
    def __init__(self, rows, runopts, cidx):
        self.runopts = runopts
        self.cidx = cidx
        # group by genre, popularity order preserved (rows are already ranked)
        order, groups = [], {}
        for r in rows:
            g = (r[6] if len(r) > 6 and r[6] else "") or GENRE_OTHER
            if g not in groups:
                groups[g] = []; order.append(g)
            groups[g].append(r)
        self.groups = [(g, groups[g]) for g in order]
        # covers per genre row: size a card so a cover fills the section height, then
        # see how many such cards fit across the width (so covers use the full height).
        cols0, lines0 = shutil.get_terminal_size((80, 24))
        vis_g0 = max(1, min(len(self.groups), (lines0 - 1) // OV_SECTION))
        card_h0 = max(1, (lines0 - 1) // vis_g0 - 1)
        card_w0 = round(card_h0 / AR_REP) + PAD_X + 2
        self.topn = max(1, cols0 // card_w0)
        # overview focusables: title then the row of covers, per genre
        self.ofocus = []                                  # ("title", gi) | ("game", gi, j)
        for gi, (g, grows) in enumerate(self.groups):
            self.ofocus.append(("title", gi))
            for j in range(min(self.topn, len(grows))):
                self.ofocus.append(("game", gi, j))
        self.titles = [i for i, it in enumerate(self.ofocus) if it[0] == "title"]
        self.mode = "overview"
        self.osel, self.otop = 0, 0       # overview focus index, first visible genre
        self.genre = 0                    # expanded genre index
        self.sel, self.top = 0, 0         # expanded-grid selection + scroll
        self.rects = []                   # click map: (x1, x2, y1, y2, ofocus_index)

    # ---------------------------------------------------------------- overview
    def overview_frame(self):
        cols_term, lines_term = shutil.get_terminal_size((80, 24))
        cell = cm.cell_px()
        vis_g = max(1, min(len(self.groups), (lines_term - 1) // OV_SECTION))
        sec_h = (lines_term - 1) // vis_g
        card_h = max(1, sec_h - TITLE_H - 1)                # title bar + covers + gap row
        card_w = cols_term // self.topn
        fgi = self.ofocus[self.osel][1]
        if fgi < self.otop:
            self.otop = fgi
        elif fgi >= self.otop + vis_g:
            self.otop = fgi - vis_g + 1

        header = (f"{ESC}[1mC64 kiosk{ESC}[0m  {ESC}[2m{len(self.groups)} genres · "
                  f"click a cover to play · click a genre to expand · esc quit{ESC}[0m")
        out = [f"{ESC}[2J{ESC}[H", header]
        imgs = []
        self.rects = []
        for vi in range(vis_g):
            gi = self.otop + vi
            if gi >= len(self.groups):
                break
            genre, grows = self.groups[gi]
            base = 2 + vi * sec_h
            ti = self.titles[gi]
            cnt = len(grows)
            out.append(self.genre_bar(genre, cnt, base, cols_term,
                                      self.osel == ti, "click / ⏎ to open"))
            self.rects.append((1, cols_term, base, base + TITLE_H - 1, ti))
            for j in range(min(self.topn, cnt)):
                x = 1 + j * card_w
                y = base + TITLE_H
                foc_idx = ti + 1 + j
                focused = (self.osel == foc_idx)
                cover = cover_for(grows[j], self.cidx)
                if cover and cm.HAS_IMG:                     # inset 1 col each side for focus bars
                    w, h = fit_cover(cover, cell, card_w - PAD_X - 2, card_h)
                    imgs.append((cover, x, y - 1, w, h))     # 1-based (x+1, y) -> 0-based (x, y-1)
                elif not cover:
                    out.append(f"{ESC}[{y + card_h // 2};{x + 1}H{ESC}[2m[no cover]{ESC}[0m")
                if focused:                                  # slim bright side bars = focus
                    bar = f"{ESC}[1;93m┃{ESC}[0m"
                    for i in range(card_h):
                        out.append(f"{ESC}[{y + i};{x}H{bar}"
                                   f"{ESC}[{y + i};{x + card_w - PAD_X - 1}H{bar}")
                self.rects.append((x, x + card_w - PAD_X - 1, y, y + card_h - 1, foc_idx))
        sys.stdout.write("".join(out)); sys.stdout.flush()
        for cover, x0, y0, w, h in imgs:
            subprocess.run(["wezterm", "imgcat", "--position", f"{x0},{y0}",
                            "--width", str(w), "--height", str(h),
                            "--no-move-cursor", cover], stderr=subprocess.DEVNULL)
        sys.stdout.write(cm.MOUSE_ON)            # imgcat can reset mouse tracking; re-arm it
        sys.stdout.flush()

    def hit(self, x, y):
        for x1, x2, y1, y2, idx in self.rects:
            if x1 <= x <= x2 and y1 <= y <= y2:
                return idx
        return None

    def activate_overview(self, idx):
        """Returns a row to play, or None (expands a genre)."""
        self.osel = idx
        it = self.ofocus[idx]
        if it[0] == "title":
            self.mode = "genre"; self.genre = it[1]; self.sel = self.top = 0
            return None
        return self.groups[it[1]][1][it[2]]               # ("game", gi, j) -> play

    # ----------------------------------------------------------- expanded genre
    def grid(self, cols_term, lines_term):
        cols = max(1, cols_term // TARGET_CW)
        rows = max(1, (lines_term - 1) // TARGET_CH)
        return cols, rows, cols_term // cols, (lines_term - 1) // rows

    def genre_frame(self):
        cols_term, lines_term = shutil.get_terminal_size((80, 24))
        cols, vis_rows, card_w, card_h = self.grid(cols_term, lines_term)
        cell = cm.cell_px()
        grows = self.groups[self.genre][1]
        n = len(grows)
        sel_row = self.sel // cols
        if sel_row < self.top:
            self.top = sel_row
        elif sel_row >= self.top + vis_rows:
            self.top = sel_row - vis_rows + 1

        genre = self.groups[self.genre][0]
        name = " ".join(genre.upper())
        bar = (f"  {name}    ({n} games)   click a cover to play · esc back · q quit"
               .ljust(cols_term)[:cols_term])
        header = f"{ESC}[1;97;44m{bar}{ESC}[0m"            # full-width genre title bar
        out = [f"{ESC}[2J{ESC}[H", header]
        imgs = []
        for r in range(vis_rows):
            for c in range(cols):
                idx = (self.top + r) * cols + c
                if idx >= n:
                    continue
                x = 1 + c * card_w
                y = 2 + r * card_h
                draw_cover(out, imgs, cover_for(grows[idx], self.cidx),
                           x, y, card_w - PAD_X, card_h - 1, cell, idx == self.sel)
        sys.stdout.write("".join(out)); sys.stdout.flush()
        for cover, x0, y0, w, h in imgs:
            subprocess.run(["wezterm", "imgcat", "--position", f"{x0},{y0}",
                            "--width", str(w), "--height", str(h),
                            "--no-move-cursor", cover], stderr=subprocess.DEVNULL)
        sys.stdout.write(cm.MOUSE_ON)            # imgcat can reset mouse tracking; re-arm it
        sys.stdout.flush()

    def card_at(self, x, y, cols, vis_rows, card_w, card_h):
        if y < 2:
            return None
        c, r = (x - 1) // card_w, (y - 2) // card_h
        if 0 <= c < cols and 0 <= r < vis_rows:
            idx = (self.top + r) * cols + c
            if idx < len(self.groups[self.genre][1]):
                return idx
        return None

    # ---------------------------------------------------------------- loop
    def run(self):
        # each *_loop returns a row to play, None to keep looping, or "QUIT".
        fd = sys.stdin.fileno()
        old = termios.tcgetattr(fd)
        sys.stdout.write(f"{ESC}[?1049h{ESC}[?25l{cm.MOUSE_ON}")
        try:
            tty.setraw(fd)
            while True:
                res = self.overview_loop() if self.mode == "overview" else self.genre_loop()
                if res == "QUIT":
                    return None
                if res:
                    return res
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old)
            sys.stdout.write(f"{cm.MOUSE_OFF}{ESC}[?25h{ESC}[?1049l"); sys.stdout.flush()

    def overview_loop(self):
        self.overview_frame()
        key = cm.read_key()
        last = len(self.ofocus) - 1
        if isinstance(key, tuple) and key[0] == "MOUSE":
            _, b, x, y, press = key
            if press and b == 64:
                self.osel = max(0, self.osel - 1)
            elif press and b == 65:
                self.osel = min(last, self.osel + 1)
            elif press and (b & 0b11) == 0:
                idx = self.hit(x, y)
                if idx is not None:
                    return self.activate_overview(idx)    # row, or None (expanded a genre)
            return None
        if key in ("q", "ESC"):
            return "QUIT"
        if key in ("RIGHT", "DOWN", "TAB"):
            self.osel = min(last, self.osel + 1)
        elif key in ("LEFT", "UP"):
            self.osel = max(0, self.osel - 1)
        elif key == "ENTER":
            return self.activate_overview(self.osel)
        return None

    def genre_loop(self):
        self.genre_frame()
        cols, vis_rows, card_w, card_h = self.grid(*shutil.get_terminal_size((80, 24)))
        grows = self.groups[self.genre][1]
        n = len(grows)
        key = cm.read_key()
        if isinstance(key, tuple) and key[0] == "MOUSE":
            _, b, x, y, press = key
            if press and b == 64:
                self.sel = max(0, self.sel - cols)
            elif press and b == 65:
                self.sel = min(n - 1, self.sel + cols)
            elif press and (b & 0b11) == 0:
                idx = self.card_at(x, y, cols, vis_rows, card_w, card_h)
                if idx is not None:
                    return grows[idx]
            return None
        if key == "ESC":
            self.mode = "overview"; return None           # back to genres
        if key == "q":
            return "QUIT"
        if key == "RIGHT":
            self.sel = min(n - 1, self.sel + 1)
        elif key == "LEFT":
            self.sel = max(0, self.sel - 1)
        elif key == "UP":
            self.sel = max(0, self.sel - cols)
        elif key == "DOWN":
            self.sel = min(n - 1, self.sel + cols)
        elif key == "ENTER":
            return grows[self.sel]
        return None


def main(argv):
    runopts = []
    for a in argv:
        if a in ("-w", "--warp"):           runopts.append("-w")
        elif a in ("-f", "--fullscreen"):   runopts.append("-f")
        elif a in ("-r", "--real"):         runopts.append("-r")
        elif a in ("-h", "--help"):         print(__doc__); return 0
        else:                               cm.die(f"unknown option: {a} (try --help)")

    if not os.path.exists(cm.INDEX) or not os.path.getsize(cm.INDEX):
        cm.die("index is empty (try: c64menu --refresh)")
    if not sys.stdin.isatty():
        cm.die("c64kiosk needs an interactive terminal")

    cidx = cm._cover.load_index()
    rows = cm.load_rows()
    if not rows:
        cm.die("no games to show (try: c64menu --refresh)")
    chosen = Kiosk(rows, runopts, cidx).run()
    if not chosen:
        return 0
    if chosen[1] == "local":
        cm.play(chosen[2], runopts)
    cm.fetch_and_play(chosen, runopts)
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
