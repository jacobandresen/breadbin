#!/usr/bin/env python3
"""c64kiosk - a grid "kiosk" of C64 game cards: cover on top, details below.

Lays out as many cards per row as the terminal is wide. Move with the arrow keys;
Enter downloads the game (if you don't own it yet) and plays it, or just plays it
if it's already in your collection. Type to filter, Esc/q to quit.

Usage:
  c64kiosk            open the kiosk
  c64kiosk -w|-f|-r   pass --warp / --fullscreen / --real through to c64run
"""
import os, sys, shutil, termios, tty, subprocess
import importlib.machinery as _m

HERE = os.path.dirname(os.path.abspath(__file__))
cm = _m.SourceFileLoader("c64menu", os.path.join(HERE, "c64menu")).load_module()  # reuse helpers
ESC = cm.ESC

# Cards size to fill the screen: pick the grid from these targets, then stretch each
# card to use all the width/height so covers are as large as possible.
TARGET_CW, TARGET_CH = 22, 16     # ~card size; smaller grid => bigger covers
PAD_X = 2                         # gutter between cards


def cover_for(row, cidx):
    cover = None
    try:
        cover = cm._cover.ensure_cover(cm.canon_of(row), cidx)        # libretro boxart
    except Exception:
        cover = None
    if not cover:
        cover = cm.ia_cover(row[5] if len(row) > 5 else "")           # else IA item image
    return cover


def fit_cover(cover, cell, box_w, box_h):
    """(w, h) cells that fit the cover inside box_w x box_h, preserving aspect."""
    sz = cm.image_size(cover)
    if not sz or not sz[0] or not sz[1]:
        return box_w, box_h
    iw, ih = sz
    cwpx, chpx = cell
    ar = (ih / iw) * (cwpx / chpx)            # rendered cell height per cell width
    w, h = box_w, round(box_w * ar)
    if h > box_h:
        h = box_h; w = max(1, round(h / ar))
    return max(1, w), max(1, h)


class Kiosk:
    def __init__(self, rows, runopts, cidx):
        self.all = rows
        self.runopts = runopts
        self.cidx = cidx
        self.filter = ""
        self.sel = 0
        self.top = 0                  # first visible grid row
        self.rows = list(rows)

    def apply_filter(self):
        q = self.filter.lower()
        self.rows = [r for r in self.all if q in r[3].lower()] if q else list(self.all)
        self.sel = self.top = 0

    def grid(self, cols_term, lines_term):
        """(cols, rows, card_w, card_h) - cards stretched to fill the screen."""
        cols = max(1, cols_term // TARGET_CW)
        rows = max(1, (lines_term - 1) // TARGET_CH)
        return cols, rows, cols_term // cols, (lines_term - 1) // rows

    def frame(self):
        cols_term, lines_term = shutil.get_terminal_size((80, 24))
        cols, vis_rows, card_w, card_h = self.grid(cols_term, lines_term)
        cell = cm.cell_px()
        fw, fh = card_w - PAD_X, card_h - 1                 # framed area inside the card
        box_w, box_h = max(1, fw - 2), max(1, fh - 2)        # cover sits inside the frame
        n = len(self.rows)
        sel_row = self.sel // cols if cols else 0
        if sel_row < self.top:
            self.top = sel_row
        elif sel_row >= self.top + vis_rows:
            self.top = sel_row - vis_rows + 1

        have = sum(1 for r in self.all if r[1] == "local")
        title = self.rows[self.sel][3] if self.rows else ""
        cur = f"{ESC}[7m {self.filter or 'type to filter'} {ESC}[0m"
        header = (f"{ESC}[1mC64 kiosk{ESC}[0m {cur}  {ESC}[1;93m▶ {cm.trunc(title, 40)}{ESC}[0m"
                  f"  {ESC}[2m{n} games · ●{have} here · click/↵ play · esc quit{ESC}[0m")

        out = [f"{ESC}[2J{ESC}[H", header]
        imgs = []
        for r in range(vis_rows):
            for c in range(cols):
                idx = (self.top + r) * cols + c
                if idx >= n:
                    continue
                x = 1 + c * card_w                          # 1-based screen column
                y = 2 + r * card_h                          # 1-based screen row
                cover = cover_for(self.rows[idx], self.cidx)
                if cover and cm.HAS_IMG:
                    w, h = fit_cover(cover, cell, box_w, box_h)
                    imgs.append((cover, x, y, w, h))        # cover top-left at cell (x+1,y+1)
                elif not cover:
                    out.append(f"{ESC}[{y + fh // 2};{x + 2}H{ESC}[2m[no cover]{ESC}[0m")
                if idx == self.sel:                          # bright frame = focus
                    out.append(self.focus_frame(x, y, fw, fh))
        sys.stdout.write("".join(out)); sys.stdout.flush()

        for cover, x0, y0, w, h in imgs:
            subprocess.run(["wezterm", "imgcat", "--position", f"{x0},{y0}",
                            "--width", str(w), "--height", str(h),
                            "--no-move-cursor", cover], stderr=subprocess.DEVNULL)
        sys.stdout.flush()

    def focus_frame(self, x, y, fw, fh):
        c = f"{ESC}[1;93m"                                   # bright yellow, bold
        top = f"{ESC}[{y};{x}H{c}┏{'━' * (fw - 2)}┓{ESC}[0m"
        bot = f"{ESC}[{y + fh - 1};{x}H{c}┗{'━' * (fw - 2)}┛{ESC}[0m"
        sides = "".join(f"{ESC}[{y + i};{x}H{c}┃{ESC}[0m"
                        f"{ESC}[{y + i};{x + fw - 1}H{c}┃{ESC}[0m"
                        for i in range(1, fh - 1))
        return top + sides + bot

    def card_at(self, x, y, cols, vis_rows, card_w, card_h):
        """View index of the card under screen cell (x, y), or None."""
        if y < 2:
            return None
        c, r = (x - 1) // card_w, (y - 2) // card_h
        if 0 <= c < cols and 0 <= r < vis_rows:
            idx = (self.top + r) * cols + c
            if idx < len(self.rows):
                return idx
        return None

    def run(self):
        fd = sys.stdin.fileno()
        old = termios.tcgetattr(fd)
        sys.stdout.write(f"{ESC}[?1049h{ESC}[?25l{cm.MOUSE_ON}")
        try:
            tty.setraw(fd)
            while True:
                self.frame()
                cols, vis_rows, card_w, card_h = self.grid(*shutil.get_terminal_size((80, 24)))
                key = cm.read_key()
                n = len(self.rows)
                if isinstance(key, tuple) and key[0] == "MOUSE":
                    _, b, x, y, press = key
                    if not press:
                        continue
                    if b == 64:                          # wheel up -> previous row
                        self.sel = max(0, self.sel - cols)
                    elif b == 65:                        # wheel down -> next row
                        self.sel = min(n - 1, self.sel + cols)
                    elif (b & 0b11) == 0:                # left click -> start that game
                        idx = self.card_at(x, y, cols, vis_rows, card_w, card_h)
                        if idx is not None:
                            self.sel = idx
                            return self.rows[idx]
                    continue
                if key in ("q", "ESC"):
                    if key == "ESC" and self.filter:
                        self.filter = ""; self.apply_filter(); continue
                    return None
                elif key == "LEFT":
                    self.sel = max(0, self.sel - 1)
                elif key == "RIGHT":
                    self.sel = min(n - 1, self.sel + 1)
                elif key == "UP":
                    self.sel = max(0, self.sel - cols)
                elif key == "DOWN":
                    self.sel = min(n - 1, self.sel + cols)
                elif key == "ENTER":
                    if self.rows:
                        return self.rows[self.sel]
                elif key == "BACKSPACE":
                    if self.filter:
                        self.filter = self.filter[:-1]; self.apply_filter()
                elif key and len(key) == 1 and 32 <= ord(key) < 127:
                    self.filter += key; self.apply_filter()
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old)
            sys.stdout.write(f"{cm.MOUSE_OFF}{ESC}[?25h{ESC}[?1049l"); sys.stdout.flush()


def main(argv):
    runopts = []
    for a in argv:
        if a in ("-w", "--warp"):           runopts.append("-w")
        elif a in ("-f", "--fullscreen"):   runopts.append("-f")
        elif a in ("-r", "--real"):         runopts.append("-r")
        elif a in ("-h", "--help"):         print(__doc__); return 0
        else:                               cm.die(f"unknown option: {a} (try --help)")

    if not os.path.exists(cm.INDEX) or not os.path.getsize(cm.INDEX):
        cm.die("index is empty (try: c64menu --refresh)")
    if not sys.stdin.isatty():
        cm.die("c64kiosk needs an interactive terminal")

    cidx = cm._cover.load_index()
    rows = cm.load_rows()
    if not rows:
        cm.die("no games to show (try: c64menu --refresh)")
    chosen = Kiosk(rows, runopts, cidx).run()
    if not chosen:
        return 0
    if chosen[1] == "local":
        cm.play(chosen[2], runopts)
    cm.fetch_and_play(chosen, runopts)
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
