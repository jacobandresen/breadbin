#!/usr/bin/env python3
#
# breadbin - Commodore 64 game library: find . fetch . launch.
#   (named after the "breadbin" - the classic beige C64 case)
#
# A thin umbrella over the toolkit. The standalone c64run / c64menu / c64get /
# c64disk commands still work; this just gives them one memorable entry point.
#
import os, sys

HERE = os.path.dirname(os.path.abspath(os.path.realpath(__file__)))

USAGE = """breadbin - Commodore 64 game library (find . fetch . launch)

  breadbin menu              browse ranked games; play owned, fetch the rest (default)
  breadbin kiosk             grid of game cards (cover + details); play/fetch on Enter
  breadbin play  <name>      launch a game straight into the emulator (LOAD"*",8,1 : RUN)
  breadbin info  <name>      show GameBase64 details for a game (year, genre, author, ...)
  breadbin get   <name>      download a tape from the Ultimate Tape Archive
  breadbin disk  <name>      download a disk from the Internet Archive / TOSEC
  breadbin disk  --source all <name>
  breadbin tosec             browse the whole TOSEC catalogue; download + play on pick

Add --help to any subcommand for its own options, e.g.  breadbin disk --help
"""

COMMANDS = {
    "menu": "c64menu", "pick": "c64menu", "browse": "c64menu",
    "kiosk": "c64kiosk", "grid": "c64kiosk", "cards": "c64kiosk",
    "play": "c64run", "run": "c64run", "launch": "c64run",
    "info": "c64info", "details": "c64info",
    "get": "c64get", "tape": "c64get",
    "disk": "c64disk",
    "tosec": "c64tosec", "browse-all": "c64tosec",
}


def main(argv):
    cmd = argv[0] if argv else "menu"
    rest = argv[1:]
    if cmd in ("-h", "--help", "help"):
        print(USAGE)
        return 0
    script = COMMANDS.get(cmd)
    if not script:
        print(f'breadbin: unknown command "{cmd}" (try: breadbin --help)', file=sys.stderr)
        return 2
    path = os.path.join(HERE, script)
    os.execv(path, [path, *rest])


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
